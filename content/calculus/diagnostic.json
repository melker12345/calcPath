  "questions": [
    {
      "id": "calc-diag-fn-1",
      "prerequisiteId": "function-notation",
      "prompt": "If $f(x)=2x+3$, what is $f(4)$?",
      "type": "numeric",
      "answer": "11",
      "explanation": "Substitute $x=4$: $f(4)=2(4)+3=11$.",
      "difficulty": "easy"
    },
    {
      "id": "calc-diag-fn-2",
      "prerequisiteId": "function-notation",
      "prompt": "If $g(x)=x^2-1$, what is $g(3)$?",
