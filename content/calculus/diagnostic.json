      "answer": "8",
      "explanation": "$g(3)=3^2-1=8$.",
      "difficulty": "easy"
    },
    {
      "id": "calc-diag-fn-3",
      "prerequisiteId": "function-notation",
      "prompt": "If $f(x)=x^2+2x$, what is $f(-1)$?",
